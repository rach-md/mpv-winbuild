[binaries]
c = '@LLVM_LOCATION@/bin/@TARGET_ARCH@-gcc'
cpp = '@LLVM_LOCATION@/bin/@TARGET_ARCH@-g++'
as = '@LLVM_LOCATION@/bin/@TARGET_ARCH@-gcc'
ar = '@LLVM_LOCATION@/bin/@TARGET_ARCH@-ar'
strip = '@LLVM_LOCATION@/bin/@TARGET_ARCH@-strip'
windres = '@LLVM_LOCATION@/bin/@TARGET_ARCH@-windres'
dlltool = '@LLVM_LOCATION@/bin/@TARGET_ARCH@-dlltool'
pkg-config = 'pkgconf'
nasm = 'nasm'
# exe_wrapper = 'wine'

[host_machine]
system = 'windows'
cpu_family = '@TARGET_CPU_FAMILY@'
cpu = '@TARGET_ARCH@'
endian = 'little'

[built-in options]
prefix = '@MINGW_INSTALL_PREFIX@'
libdir = '@MINGW_INSTALL_PREFIX@/lib'
buildtype = 'release'
default_library = 'static'
prefer_static = true
wrap_mode = 'nofallback'
